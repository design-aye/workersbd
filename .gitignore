# ========================
# WorkersBD - .gitignore
# ========================

# Dependencies
node_modules/
/.pnp
.pnp.js

# Next.js build output
/.next/
/out/
/build/

# Vercel
.vercel/

# Environment files - NEVER commit these
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# Only .env.example should be committed
# .env.example is intentionally NOT listed here

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Testing
/coverage/
/.nyc_output

# Misc
*.log
*.pid
*.seed
*.pid.lock

# Bundle analyzer
/.analyze/
/analyze/

# Sitemap (auto-generated)
/public/sitemap*.xml
/public/robots.txt

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Tailwind JIT cache
.tailwindcss/

# PWA
/public/sw.js
/public/workbox-*.js
/public/worker-*.js
/public/fallback-*.js
/public/sw.js.map
/public/workbox-*.js.map

# Uploads (local dev only)
/public/uploads/

# mnt (local AI output path - not part of project)
/mnt/
